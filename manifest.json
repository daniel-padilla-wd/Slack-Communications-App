{
    "display_information": {
        "name": "Slack Communications App",
        "description": "To empower our communications team to send flexible, branded, and actionable messages to multiple Slack channels.",
        "background_color": "#000000"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": false,
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": false
        },
        "bot_user": {
            "display_name": "Slack Communications App",
            "always_online": false
        },
        "shortcuts": [
            {
                "name": "Send BT Comms",
                "type": "global",
                "callback_id": "bt_comms_shortcut",
                "description": "Compose and send a message to one or more channels and/or users with optional custom sender details and CTA buttons."
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "chat:write",
                "commands",
                "users:read.email",
                "users:read",
                "chat:write.customize",
                "chat:write.public"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": true,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}